{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for Hide Mail metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "id": null,
  "uid": "hidemail-overview",
  "title": "Hide Mail - Service Overview",
  "description": "Monitoring dashboard for hide-mail.org temporary email service",
  "tags": ["hide-mail", "email", "smtp", "prometheus"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(hidemail_process_cpu_seconds_total, job)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "job",
        "options": [],
        "query": { "query": "label_values(hidemail_process_cpu_seconds_total, job)", "refId": "A" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "Service Status",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "up{job=~\"$job\"}", "legendFormat": "Service", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Disconnected" }, "1": { "color": "green", "text": "Connected" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "Redis",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_redis_connected{job=~\"$job\"}", "legendFormat": "Redis", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "title": "Process Uptime",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_process_start_time_seconds{job=~\"$job\"}", "legendFormat": "", "refId": "A", "instant": true }
      ],
      "transformations": [
        { "id": "calculateField", "options": { "mode": "reduceRow", "reduce": { "reducer": "lastNotNull" } } }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 268435456 }, { "color": "red", "value": 536870912 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "title": "Heap Used",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_nodejs_heap_size_used_bytes{job=~\"$job\"}", "legendFormat": "Heap Used", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 536870912 }, { "color": "red", "value": 1073741824 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "title": "RSS Memory",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_process_resident_memory_bytes{job=~\"$job\"}", "legendFormat": "RSS", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "title": "Event Loop Lag (ms)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_nodejs_eventloop_lag_seconds{job=~\"$job\"} * 1000", "legendFormat": "Lag", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "Mailbox Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 6 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "title": "Total Registrations",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_mailbox_registrations_total{job=~\"$job\"}", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 6 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "title": "Total Refreshes",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_mailbox_refreshes_total{job=~\"$job\"}", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 6 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "title": "Total Deactivations",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_mailbox_deactivations_total{job=~\"$job\"}", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "lineWidth": 2 },
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Mailbox Operations Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_mailbox_registrations_total{job=~\"$job\"}[5m])", "legendFormat": "Registrations", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_mailbox_refreshes_total{job=~\"$job\"}[5m])", "legendFormat": "Refreshes", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_mailbox_deactivations_total{job=~\"$job\"}[5m])", "legendFormat": "Deactivations", "refId": "C" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 300,
      "title": "SMTP / Email Processing",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 15 },
      "id": 20,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "title": "SMTP Connections",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_smtp_connections_total{job=~\"$job\"}", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 15 },
      "id": 21,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "title": "Emails Received",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_emails_received_total{job=~\"$job\"}", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 15 },
      "id": 22,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "title": "Emails Stored",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_emails_stored_total{job=~\"$job\"}", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 15 },
      "id": 23,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "title": "Emails Dropped",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "hidemail_emails_dropped_total{job=~\"$job\"}", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "lineWidth": 2 },
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 24,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Email Throughput",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_emails_received_total{job=~\"$job\"}[5m])", "legendFormat": "Received", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_emails_stored_total{job=~\"$job\"}[5m])", "legendFormat": "Stored", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_emails_dropped_total{job=~\"$job\"}[5m])", "legendFormat": "Dropped ({{reason}})", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "pointSize": 5, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 25,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "SMTP Recipients",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_smtp_recipients_accepted_total{job=~\"$job\"}[5m])", "legendFormat": "Accepted", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_smtp_recipients_rejected_total{job=~\"$job\"}[5m])", "legendFormat": "Rejected ({{reason}})", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "pointSize": 5, "lineWidth": 1 },
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 26,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "SMTP Errors Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(hidemail_smtp_errors_total{job=~\"$job\"}[5m])", "legendFormat": "Errors/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2, "scaleDistribution": { "type": "log", "log": 2 } },
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 27,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Email Size Distribution (p50 / p90 / p99)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, rate(hidemail_email_size_bytes_bucket{job=~\"$job\"}[5m]))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, rate(hidemail_email_size_bytes_bucket{job=~\"$job\"}[5m]))", "legendFormat": "p90", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, rate(hidemail_email_size_bytes_bucket{job=~\"$job\"}[5m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 400,
      "title": "HTTP API",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "lineWidth": 2 },
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "HTTP Request Rate by Route",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (route) (rate(hidemail_http_requests_total{job=~\"$job\"}[5m]))", "legendFormat": "{{route}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "lineWidth": 2 },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "HTTP Latency p95 by Route",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (route, le) (rate(hidemail_http_request_duration_seconds_bucket{job=~\"$job\"}[5m])))", "legendFormat": "{{route}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "pointSize": 5, "lineWidth": 1, "stacking": { "mode": "normal" } },
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "id": 32,
